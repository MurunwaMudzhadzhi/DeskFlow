{
  "info": {
    "name": "DeskFlow API",
    "description": "Internal IT Service Request Portal - API collection covering authentication and ticket management endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "d3f10101-a001-4b1c-8e9a-deskflow00001"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"employee1\",\n  \"password\": \"Employee@123\",\n  \"role\": \"employee\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token returned', () => pm.expect(res.data.token).to.be.a('string'));",
                  "if (res.data && res.data.token) { pm.environment.set('token', res.data.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin1\",\n  \"password\": \"Admin@123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "if (res.data && res.data.token) { pm.environment.set('adminToken', res.data.token); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket (Employee)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Laptop will not power on\",\n  \"description\": \"Screen stays black even after holding the power button for 10 seconds.\",\n  \"priority\": \"High\",\n  \"category\": \"Hardware\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "if (res.data && res.data._id) { pm.environment.set('ticketId', res.data._id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Tickets (Employee - own only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Get Tickets (Admin - all, filtered)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tickets?status=Open&priority=High",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets"],
              "query": [
                { "key": "status", "value": "Open" },
                { "key": "priority", "value": "High" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Update Ticket Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\",\n  \"resolutionNotes\": \"Dispatched a replacement charger to the employee.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "{{ticketId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Update Ticket Status - Forbidden (Employee attempt)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Resolved\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "{{ticketId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 403', () => pm.response.to.have.status(403));"]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "ticketId", "value": "" }
  ]
}
